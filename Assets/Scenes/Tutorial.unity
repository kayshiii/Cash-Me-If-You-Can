  choices: {fileID: 84478029}
  promptText: {fileID: 533792773}
  buttonsGO: {fileID: 2003556523}
  finalPromptText: {fileID: 336605477}
  finalChoices: {fileID: 1542980888}
  finalButtons: {fileID: 1012569580}
  uwianAnim: {fileID: 2123956654}
  condoAnim: {fileID: 1238184588}
  staycationAnim: {fileID: 1302389055}
  savingAnim: {fileID: 398060215}
  sellingAnim: {fileID: 1608674948}
  staycationText: {fileID: 1541615756}
  savingText: {fileID: 157656001}
  sellingText: {fileID: 1093048591}
  uwianText: {fileID: 1355355410}
  condoText: {fileID: 240645525}
  dialogueManager: {fileID: 1572517996}
  gameManager: {fileID: 457017614}
  delayBetweenReveals: 3
  OnhandcashText: {fileID: 1020710111}
  iponInfoText: {fileID: 1020710111}
  dailyNeedsInfoText: {fileID: 1020710111}
  lakwatsaInfoText: {fileID: 1020710111}
  socialText: {fileID: 1020710111}
  happinessText: {fileID: 1020710111}
  focusText: {fileID: 1020710111}
  budgetGoalText: {fileID: 1020710111}
  currentCashText: {fileID: 1020710111}
  onhandCashInfo:
    text: "Ito ang total na pera mo ngayon.\r\nKasama dito ang allowance at natirang
      pera from previous levels.\r"
  iponInfo:
    text: "Para sa long-term goal mo na PHP 80,000.\r\nMas malaki ang ipon \u2192
      mas mataas ang Focus at Stability."
  dailyNeedsInfo:
    text: "Pagkain, pamasahe, load, essentials.\r\nWag masyadong tipirin\u2014tao
      si Alex, hindi robot."
  lakwatsaInfo:
    text: "Gala, kape, bonding with friends.\r\nNakakapasaya\u2014pero wag sosobra."
  promptMessage:
    text: 'May plano ang barkada mo

      Pre-college staycation sa Batangas.'
  finalPromptMessage:
    text: Do you think Alex is responsible enough to budget if she chooses a condo
      or dorm? Or would commuting home be a better choice to stray away from over
      spending?
  socialInfoText:
    text: "Pakikisalamuha sa friends.\r\nSobra \u2192 distracted.\r\nKulang \u2192
      lonely, low morale."
  happinessInfoText:
    text: "Mental state ni Alex.\r\nMababa \u2192 burnout.\r\nMataas \u2192 better
      performance."
  focusInfoText:
    text: 'Academic performance.

      Mas mataas = scholarships & opportunities
      later.'
  budgetGoalInfoText:
    text: Long-term savings goal.
  currentCashInfoText:
    text: 'Natitirang pera after budgeting.

      Unused cash rolls over to next
      level.'
  staycationInfo:
    text: "The salty breeze fills the air as Alex laughs with friends by the beach.
      Photos, food, and sunsets \u2014 moments to remember before college begins.
      But somewhere between the waves, a quiet thought lingers: back to reality soon"
  savingInfo:
    text: "While everyone\u2019s posting beach photos, Alex scrolls through the feed
      alone. The room is quiet, but the wallet\u2019s a bit heavier. A small sigh
      escapes \u2014 \u201CNext time, siguro.\u201D Still, the thought of that growing
      savings brings calm comfort"
  sellingInfo:
    text: "Flour dust dances under the kitchen light as Alex packs another batch
      of freshly baked cookies. Orders are coming in faster than expected. It\u2019s
      tiring, sure \u2014 but each sold pack feels like a small step toward something
      bigger"
  uwianInfo:
    text: "The morning rush hums outside as Alex squeezes into the jeepney, bag snug
      on the lap. Every peso saved means packed lunches and long rides \u2014 but
      also family dinners and Lola\u2019s warm \u201CIngat ha.\u201D The days may
      be tiring, but home is just one commute away"
  condoInfo:
    text: "Alex unlocks the small condo door \u2014 quiet, tidy, and fully theirs.
      Groceries on the table, budget scribbled on a sticky note. Freedom tastes sweet,
      but so does instant noodles after a long day. For the first time, every choice
      \u2014 from spending to surviving \u2014 is all up to Alex"
