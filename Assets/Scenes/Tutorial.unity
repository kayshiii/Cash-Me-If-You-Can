  m_Script: {fileID: 11500000, guid: e345df1abe578564b9104925774ccf7a, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialoguePanel: {fileID: 2010061708}
  tutorialDialogueLines:
  - speaker: Mom
    text: Congrats, Nak! College ka na! Tapos mo na ang high school, sobrang proud
      kami sayo.
  - speaker: Dad
    text: Oo nga. Lahat ng puyat at pagod mo, sulit na sulit.
  - speaker: Alex
    text: Salamat po, Ma! Pa!
  - speaker: Mom
    text: Eto pala, Nak. Graduation gift namin ng Papa mo.
  - speaker: popup
    text: + PHP 5,000
  - speaker: Mom
    text: Pwede mong ipunin, gastusin, o pang-start ng maliit na sideline.
  - speaker: Alex
    text: "Ang laki po nito\u2026 sure po ba kayo?"
  - speaker: Dad
    text: Deserve mo yan. Ikaw na bahala kung paano mo gagamitin.
  tutorialLolaLines:
  - speaker: lola mom
    text: 'Ay, Alex! Bago ka mag-enjoy, turuan muna kita mag-budget.

'
  - speaker: lola mom
    text: Hindi lahat ng may pera, marunong humawak ng pera ha
  finalTutorialDialogueLines:
  - speaker: dad
    text: Nak, malapit na pasukan. Paano commute mo?
  tutorialLolaPromptLines:
  - speaker: lola mom
    text: 'May plano ang barkada mo

      Pre-college staycation sa Batangas.'
  - speaker: lola mom
    text: "Pero pwede ka rin:\r\n- Iponin ang graduation gift\r\n- Magbenta ng cookies
      para dagdag puhunan\r"
  speakerText: {fileID: 974638408}
  lineDelay: 0.5
  typeSpeed: 0.001
